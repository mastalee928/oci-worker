# Force LF line endings for files that must run on Linux servers.
# Prevents "bad interpreter: /usr/bin/env bash^M" failures when the repo is
# checked out on Windows with core.autocrlf=true.

*.sh         text eol=lf
ociworker    text eol=lf
*.service    text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
Dockerfile   text eol=lf
